# ============================================================================
#  settings.env — parametres de la capsule. Edite ici pour une autre machine.
# ============================================================================

# --- Prefix Wine (cible d'installation) ---
WINEPREFIX_DIR="$HOME/softs/wine-flashcs6"
WINEARCH=win32
WIN_VERSION=win7

# --- Sous-dossier d'install de Flash dans le prefix ---
FLASH_INSTALL_SUBDIR="drive_c/Program Files/Adobe/Adobe Flash CS6"

# --- Tablette Huion ---
TABLET_VID=256c
TABLET_PID=006e
# Sortie xrandr de la Kamvas (celle en 1920x1080). Verifie : xrandr --listmonitors
KAMVAS_OUTPUT=HDMI-0

# --- Fichiers que TU deposes dans local/ (gitignore, jamais sur GitHub) ---
LOCAL_ISO_GLOB="local/*.iso"
LOCAL_AMTLIB="local/amtlib.dll"

# --- Pack hors-ligne (Wine + deps + binaires) sur une Release GitHub ---
# install.sh telecharge ce pack UNE fois et le met en cache dans vendor/.
# Laisse vide pour le mode "build depuis la source" (Wine pre-installe requis).
WINE_PACK_URL=""
